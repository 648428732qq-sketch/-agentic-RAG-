# ============================================================
#  中医医院智能知识库 — 环境变量配置
# ============================================================

# Langfuse 可观测性（可选）
# 设置 LANGFUSE_ENABLED=true 并提供 API 密钥以启用追踪
# 从 https://cloud.langfuse.com 获取密钥
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3000

# LLM 提供商 API 密钥（根据需要设置）
# 默认使用本地 Ollama，无需设置以下密钥
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
ACTIVE_LLM_CONFIG=deepseek

# 跨平台目录。留空时使用项目根目录下的默认位置；Linux 可填绝对挂载路径。
MARKDOWN_DIR=
PARENT_STORE_PATH=
QDRANT_DB_PATH=

# 留空使用本地嵌入式 Qdrant；服务器可填 http://127.0.0.1:6333。
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false

# 结构化方证检索
# 严格模式下，数据库证据不足时追问或拒答，不用模型常识补方。
STRICT_LOCAL_EVIDENCE_MODE=true
ENABLE_HYBRID_SYNDROME_RETRIEVAL=true
SYNDROME_MIN_QUERY_COVERAGE=1.0
SYNDROME_MIN_EVIDENCE_CONFIDENCE=0.60
DENSE_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_LOCAL_FILES_ONLY=true
# 留空或 auto 让 sentence-transformers 自动选设备；服务器可显式填 cuda。
EMBEDDING_DEVICE=auto

# Query Translator（可选 LLM 增强；本地规则始终作为校验和降级链）
ENABLE_LLM_SYMPTOM_TRANSLATOR=true
LLM_SYMPTOM_TRANSLATOR_ALWAYS=false
LLM_SYMPTOM_TRANSLATOR_MIN_LOCAL_TERMS=3
LLM_SYMPTOM_TRANSLATOR_TIMEOUT_SECONDS=12
LLM_SYMPTOM_TRANSLATOR_CONNECT_TIMEOUT_SECONDS=4

# 本地 V3 双塔只扩展候选规范词；Qdrant payload 和证据门控仍决定是否回答。
ENABLE_QUERY_TRANSLATOR_BIENCODER=false
QUERY_TRANSLATOR_BIENCODER_MODEL=artifacts/query_translator/20260630_biencoder_v3/model
QUERY_TRANSLATOR_BIENCODER_CATALOG=artifacts/query_translator/20260630_biencoder_v3/term_catalog.jsonl
QUERY_TRANSLATOR_BIENCODER_DEVICE=cpu
QUERY_TRANSLATOR_BIENCODER_TOP_K=5
QUERY_TRANSLATOR_BIENCODER_PRIMARY_K=3
QUERY_TRANSLATOR_BIENCODER_MIN_SCORE=0.55
QUERY_TRANSLATOR_BIENCODER_LOCAL_TERM_THRESHOLD=3

# CrossEncoder 二级重排。默认关闭，先用排名盲测证明收益再启用。
ENABLE_SYNDROME_RERANK=false
SYNDROME_RERANK_MODEL=BAAI/bge-reranker-v2-m3
SYNDROME_RERANK_CANDIDATES=8
SYNDROME_RERANK_INTENTS=clinical_symptom
SYNDROME_RERANK_MODE=evidence_first
SYNDROME_RERANK_LOCAL_FILES_ONLY=true
SYNDROME_RERANK_MAX_LENGTH=256
SYNDROME_RERANK_BATCH_SIZE=8
# 留空或 auto 自动选择；安装 CUDA 版 PyTorch 后可显式填 cuda。
SYNDROME_RERANK_DEVICE=auto
SYNDROME_RERANK_CACHE_FOLDER=
SYNDROME_RERANK_TRUST_REMOTE_CODE=false

# WebUI：服务器部署时改为 0.0.0.0，并通过防火墙/反向代理限制访问。
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false

# 动态代理（可选，仅供爬虫使用；完整 URL 可能含签名，禁止提交真实值）
JULIANG_PROXY_API_URL=
